{
  "name": "round2-backend",
  "version": "1.0.0",
  "description": "Minimal real-time telemetry ingest and display backend for Round 2",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "build": "node scripts/build.js",
    "build:render": "npm ci --include=dev && npm run db:generate && npm run build",
    "start": "node src/server.js",
    "start:dist": "node dist/server.js",
    "simulator": "node src/simulator/vehicleRecorderSimulator.js",
    "simulator:control": "node src/simulator/realtimeControlSimulator.js",
    "postinstall": "npm run db:generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
      "db:migrate": "prisma migrate dev --name init",
      "db:seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "Agniva",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
}
