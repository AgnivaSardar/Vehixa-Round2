generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId           String            @id @default(uuid())
  name             String?
  email            String            @unique
  password         String?
  phone            String?
  role             Role              @default(USER)
  isActive         Boolean           @default(true)
  isVerified       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  // Fleet management fields
  fleetRole         FleetRole?
  companyName       String?
  isApproved        Boolean          @default(false)
  avatarUrl         String?
  
  alerts            Alert[]
  otpVerifications  OTPVerification[]
  vehicle           Vehicle[]
  driverProfile     DriverProfile?
  dispatchesCreated DispatchRequest[] @relation("CreatedBy")
  assignedDispatches DispatchRequest[] @relation("AssignedDriver")
  supportTickets    SupportTicket[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([fleetRole])
}

model Vehicle {
  vehicleId        String                   @id @default(uuid())
  userId           String
  vehicleNumber    String?                  @unique
  model            String?
  manufacturer     String?
  year             Int?
  vehicleType      VehicleType?
  vin              String?                  @unique
  engineType       EngineType?
  fuelType         FuelType
  registrationDate DateTime?
  status           VehicleOperationalStatus @default(ACTIVE)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  
  // Fleet management fields
  engineNumber      String?
  rcDocumentUrl     String?
  rcExpiryDate      DateTime?
  fuelLevel         Int?                     @default(0)
  currentLocation   String?
  odometer          Float?
  
  alerts            Alert[]
  healthRecords     HealthPrediction[]
  telemetry         Telemetry[]
  telemetry2        Telemtery2[]
  user              User                     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  vehicleApiKeys    VehicleApiKey[]
  insurancePolicies InsurancePolicy[]
  maintenanceOrders MaintenanceOrder[]
  dispatchRequests  DispatchRequest[]
  driverProfiles    DriverProfile[]          @relation("AssignedVehicle")
  vehicleComponents VehicleComponent[]
  complianceRecords ComplianceRecord[]

  @@index([userId])
  @@index([status])
}

model Telemetry {
  telemetryId        String            @id @default(uuid())
  vehicleId          String
  source             TelemetrySource?
  engineTemp         Float?
  batteryVoltage     Float?
  rpm                Int?
  oilPressure        Float?
  mileage            Float?
  vibrationLevel     Float?
  fuelEfficiency     Float?
  errorCodesCount    Int?
  ambientTemperature Float?
  coolantLevel       Float?
  recordedAt         DateTime
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  healthPrediction   HealthPrediction?
  vehicle            Vehicle           @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId, recordedAt])
}

model HealthPrediction {
  predictionId           String           @id @default(uuid())
  vehicleId              String
  telemetryId            String           @unique
  healthScore            Float
  status                 HealthStatus
  failureProbability     Float?
  riskLevel              RiskLevel?
  predictedFailureDays   Int?
  confidenceScore        Float?
  modelVersion           String?
  diagnosticAnalysis     String?
  topInfluentialFeatures String[]         @default([])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  alerts                 Alert[]
  telemetry              Telemetry        @relation(fields: [telemetryId], references: [telemetryId], onDelete: Cascade)
  vehicle                Vehicle          @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)
  recommendations        Recommendation[]

  @@index([vehicleId])
  @@index([status])
}

model Recommendation {
  recommendationId String                  @id @default(uuid())
  predictionId     String
  title            String?
  description      String?
  priority         RecommendationPriority?
  actionType       ActionType?
  actionDueDays    Int?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  healthPrediction HealthPrediction        @relation(fields: [predictionId], references: [predictionId], onDelete: Cascade)

  @@index([predictionId])
}

model Alert {
  alertId          String            @id @default(uuid())
  vehicleId        String
  predictionId     String?
  alertType        String?
  severity         AlertSeverity
  title            String
  message          String
  isResolved       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userUserId       String?
  healthPrediction HealthPrediction? @relation(fields: [predictionId], references: [predictionId], onDelete: Cascade)
  user             User?             @relation(fields: [userUserId], references: [userId])
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId])
  @@index([severity])
}

model ModelMetadata {
  id                  String    @id @default(uuid())
  version             String    @unique
  algorithm           String?
  accuracy            Float?
  precisionScore      Float?
  recallScore         Float?
  f1Score             Float?
  trainingDatasetSize Int?
  featuresUsed        String?
  trainedOn           DateTime?
  createdAt           DateTime  @default(now())
}

model VehicleApiKey {
  id        String   @id @default(uuid())
  vehicleId String
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId])
}

model OTPVerification {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([email, otp])
  @@index([expiresAt])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("PENDING")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Telemtery2 {
  id                   String           @id @default(uuid())
  vehicleId            String
  engineRpm            Float?
  lubOilPressure       Float?
  fuelPressure         Float?
  coolantPressure      Float?
  lubOilTemp           Float?
  coolantTemp          Float?
  engineTemp           Float?
  rpm                  Float?
  batteryVoltage       Float?
  oilPressure          Float?
  mileage              Float?
  vibrationLevel       Float?
  fuelEfficiency       Float?
  errorCodesCount      Int?
  coolantLevel         Float?
  ambientTemperature   Float?
  recordedAt           DateTime
  receivedAt           DateTime         @default(now())
  rawPayload           Json
  activeFaultCodes     Json?
  batteryStateOfCharge Float?
  batteryTemp          Float?
  engineLoad           Float?
  inverterTemp         Float?
  motorTemp            Float?
  speed                Float?
  throttlePosition     Float?
  source               TelemetrySource?
  vehicle              Vehicle          @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId, recordedAt])
  @@index([vehicleId, receivedAt])
  @@index([receivedAt])
  @@map("Telemtery2")
}

// ============================================================================
// FLEET MANAGEMENT MODELS
// ============================================================================

model InsurancePolicy {
  id           String    @id @default(uuid())
  vehicleId    String
  provider     String
  policyNumber String
  startDate    DateTime?
  expiryDate   DateTime
  documentUrl  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId])
  @@index([expiryDate])
}

model DriverProfile {
  id                   String        @id @default(uuid())
  userId               String        @unique
  phone                String?
  licenseNumber        String?
  licenseType          String?       @default("HGMV")
  licenseExpiry        DateTime?
  safetyScore          Int           @default(100)
  milesThisMonth       Float         @default(0)
  totalIncidents       Int           @default(0)
  onTimeRate           Int           @default(100)
  yearsExperience      Int           @default(0)
  assignedVehicleId    String?
  status               DriverStatus  @default(AVAILABLE)
  aadharNumber         String?
  medicalCertExpiry    DateTime?
  address              String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user            User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  assignedVehicle Vehicle? @relation("AssignedVehicle", fields: [assignedVehicleId], references: [vehicleId], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([assignedVehicleId])
}

model DispatchRequest {
  id            String            @id @default(uuid())
  ticketNumber  String            @unique
  origin        String
  destination   String
  cargoType     String?
  cargoWeight   String?
  priority      DispatchPriority  @default(STANDARD)
  status        DispatchStatus    @default(PENDING)
  driverId      String?
  vehicleId     String?
  progressPct   Int               @default(0)
  eta           String?
  speed         Float?            @default(0)
  createdById   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  driver          User?             @relation("AssignedDriver", fields: [driverId], references: [userId], onDelete: SetNull)
  vehicle         Vehicle?          @relation(fields: [vehicleId], references: [vehicleId], onDelete: SetNull)
  createdBy       User?             @relation("CreatedBy", fields: [createdById], references: [userId], onDelete: SetNull)
  driverLocations DriverLocation[]

  @@index([status])
  @@index([driverId])
  @@index([vehicleId])
  @@index([createdAt])
}

model MaintenanceOrder {
  id               String              @id @default(uuid())
  vehicleId        String
  title            String
  description      String?
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(SCHEDULED)
  orderType        MaintenanceType     @default(CORRECTIVE)
  mechanicName     String?
  scheduledDate    DateTime?
  completedDate    DateTime?
  estimatedCost    Float?
  actualCost       Float?
  odometerReading  Float?
  etaParts         String?
  invoiceUrl       String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId])
  @@index([status])
  @@index([orderType])
  @@index([scheduledDate])
}

model SupportTicket {
  id          String          @id @default(uuid())
  driverId    String
  category    TicketCategory
  subject     String
  description String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  driver User @relation(fields: [driverId], references: [userId], onDelete: Cascade)

  @@index([driverId])
  @@index([status])
  @@index([category])
}

model ComplianceRecord {
  id          String          @id @default(uuid())
  vehicleId   String
  type        ComplianceType
  documentUrl String?
  issueDate   DateTime
  expiryDate  DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId])
  @@index([expiryDate])
  @@index([type])
}

model ServiceVendor {
  id          String   @id @default(uuid())
  name        String
  serviceType String
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceType])
}

model VehicleComponent {
  id                  String    @id @default(uuid())
  vehicleId           String
  componentName       String
  lastReplacementDate DateTime?
  nextReplacementDue  DateTime?
  currentCondition    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId])
  @@index([nextReplacementDue])
}

model PreventiveSchedule {
  id            String    @id @default(uuid())
  vehicleId     String
  title         String
  description   String?
  scheduledDate DateTime
  completedDate DateTime?
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([vehicleId])
  @@index([scheduledDate])
  @@index([isCompleted])
}

model AuditLog {
  id         String        @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  severity   AuditSeverity @default(INFO)
  details    Json?
  createdAt  DateTime      @default(now())

  user User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
  @@index([severity])
}

model DriverLocation {
  id         String   @id @default(uuid())
  dispatchId String
  latitude   Float
  longitude  Float
  speed      Float?
  timestamp  DateTime @default(now())

  dispatch DispatchRequest @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@index([dispatchId])
  @@index([timestamp])
}

enum Role {
  USER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID
  CNG
  LPG
  HYDROGEN
}

enum EngineType {
  INLINE
  V_TYPE
  BOXER
  ROTARY
  ELECTRIC_MOTOR
}

enum VehicleType {
  SEDAN
  HATCHBACK
  SUV
  COUPE
  CONVERTIBLE
  WAGON
  MINIVAN
  MOTORCYCLE
  SCOOTER
  PICKUP_TRUCK
  LIGHT_TRUCK
  HEAVY_TRUCK
  TRAILER
  BUS
  SCHOOL_BUS
  DELIVERY_VAN
  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID
  CONSTRUCTION
  AGRICULTURAL
  EMERGENCY
  MILITARY
  FLEET_VEHICLE
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  SEVERE
}

enum ActionType {
  INSPECT
  REPLACE
  SERVICE
  MONITOR
  CALIBRATE
  UPDATE_SOFTWARE
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum HealthStatus {
  HEALTHY
  WARNING
  CRITICAL
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TelemetrySource {
  MANUAL_ENTRY
  SIMULATOR
  OBD_DEVICE
  API_PUSH
  DIGITAL_TWIN
}

enum VehicleOperationalStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DECOMMISSIONED
}

enum FleetRole {
  ADMIN
  MANAGER
  DRIVER
}

enum DispatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
}

enum DispatchPriority {
  STANDARD
  HIGH
}

enum MaintenanceStatus {
  SCHEDULED
  IN_SERVICE
  AWAITING_PARTS
  READY
  COMPLETED
}

enum MaintenanceType {
  CORRECTIVE
  PROACTIVE
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  TRIP_ISSUE
  VEHICLE_ISSUE
  DOCUMENT_HELP
  EMERGENCY_SOS
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum ComplianceType {
  POLLUTION_CERTIFICATE
  FITNESS_CERTIFICATE
  NATIONAL_PERMIT
  STATE_PERMIT
  GOODS_PERMIT
  ROAD_TAX
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}
